<!DOCTYPE html>
<html>
<head>
<title>Kalyankar Technologies</title>

<style>
body{
    font-family: Arial;
    margin: 0;
    background-color: #f2f2f2;
}

header{
    background-color: navy;
    color: white;
    text-align: center;
    padding: 20px;
}

nav{
    background-color: lightblue;
    text-align: center;
    padding: 10px;
}

nav a{
    text-decoration: none;
    margin: 15px;
    color: black;
}

section{
    background-color: white;
    margin: 15px;
    padding: 15px;
    border: 1px solid gray;
}

h2{
    color: navy;
}

.service{
    border: 1px solid lightgray;
    padding: 10px;
    margin-top: 10px;
}

input, textarea{
    width: 300px;
    padding: 8px;
    margin-top: 5px;
}

button{
    padding: 10px;
    margin-top: 10px;
}

footer{
    background-color: navy;
    color: white;
    text-align: center;
    padding: 15px;
}
</style>
</head>

<body>

<header>
    <h1>Kalyankar Technologies</h1>
    <p>Simple Software and Web Solutions</p>
</header>

<nav>
    <a href="#home">Home</a>
    <a href="#services">Services</a>
    <a href="#about">About</a>
    <a href="#contact">Contact</a>
</nav>

<section id="home">
    <h2>Welcome</h2>

    <p>
        Welcome to Kalyankar Technologies.
        We provide software development and website development services.
    </p>
</section>

<section id="services">
    <h2>Services</h2>

    <div class="service">
        <h3>Website Development</h3>
        <p>Creating simple websites using HTML, CSS and JavaScript.</p>
    </div>

    <div class="service">
        <h3>Software Development</h3>
        <p>Developing software projects for students and businesses.</p>
    </div>

    <div class="service">
        <h3>AI Projects</h3>
        <p>Basic AI and machine learning project development.</p>
    </div>
</section>

<section id="about">
    <h2>About Us</h2>

    <p>
        Kalyankar Technologies is a student project company website.
        The purpose of this project is to demonstrate HTML, CSS and JavaScript concepts.
    </p>
</section>

<section id="contact">
    <h2>Contact Us</h2>

    <form onsubmit="showMessage(); return false;">

        <input type="text" placeholder="Enter Name" required>
        <br><br>

        <input type="email" placeholder="Enter Email" required>
        <br><br>

        <textarea rows="4" placeholder="Enter Message"></textarea>
        <br><br>

        <button type="submit">Send</button>

    </form>
</section>

<footer>
    <p>© 2026 Kalyankar Technologies</p>
</footer>

<script>
function showMessage()
{
    alert("Message Sent Successfully");
}
</script>

</body>
</html>
