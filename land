```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kalyankar Technologies</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f5f7fa;
}

/* Header */
header{
    background:#0f172a;
    color:white;
    padding:15px 8%;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo-container{
    display:flex;
    align-items:center;
    gap:10px;
}

.logo{
    width:45px;
    height:45px;
    border-radius:50%;
    background:#38bdf8;
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:24px;
    font-weight:bold;
}

.company-name{
    font-size:24px;
    font-weight:bold;
}

nav a{
    color:white;
    text-decoration:none;
    margin-left:20px;
}

nav a:hover{
    color:#38bdf8;
}

/* Hero Section */
.hero{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:80px 10%;
    background:linear-gradient(to right,#0f172a,#1e293b);
    color:white;
}

.hero-text{
    width:50%;
}

.hero-text h1{
    font-size:50px;
    margin-bottom:15px;
}

.hero-text p{
    margin-bottom:20px;
    line-height:1.7;
}

.btn{
    background:#38bdf8;
    color:black;
    text-decoration:none;
    padding:12px 25px;
    border-radius:25px;
    font-weight:bold;
}

.btn:hover{
    background:white;
}

.hero-image{
    width:40%;
    text-align:center;
}

.hero-image img{
    width:100%;
    max-width:350px;
}

/* Sections */
section{
    padding:70px 10%;
}

.title{
    text-align:center;
    font-size:35px;
    margin-bottom:40px;
    color:#0f172a;
}

/* Services */
.services{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.card{
    background:white;
    padding:25px;
    border-radius:10px;
    box-shadow:0 0 10px rgba(0,0,0,0.1);
    text-align:center;
}

.card h3{
    margin-bottom:10px;
    color:#0f172a;
}

/* About */
.about{
    background:#e2e8f0;
    text-align:center;
    line-height:1.8;
}

/* Contact */
.contact{
    text-align:center;
}

.contact input,
.contact textarea{
    width:80%;
    padding:12px;
    margin:10px 0;
    border:1px solid #ccc;
    border-radius:5px;
}

.contact button{
    padding:12px 25px;
    border:none;
    background:#38bdf8;
    font-weight:bold;
    cursor:pointer;
    border-radius:5px;
}

/* Footer */
footer{
    background:#0f172a;
    color:white;
    text-align:center;
    padding:20px;
}

/* Mobile */
@media(max-width:768px){

.hero{
    flex-direction:column;
    text-align:center;
}

.hero-text,
.hero-image{
    width:100%;
}

.hero-text h1{
    font-size:35px;
}

nav{
    display:none;
}
}
</style>
</head>

<body>

<!-- Header -->
<header>

<div class="logo-container">
    <div class="logo">K</div>
    <div class="company-name">Kalyankar Technologies</div>
</div>

<nav>
    <a href="#home">Home</a>
    <a href="#services">Services</a>
    <a href="#about">About</a>
    <a href="#contact">Contact</a>
</nav>

</header>

<!-- Hero Section -->
<section class="hero" id="home">

